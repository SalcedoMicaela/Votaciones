# Conexión a MongoDB (Atlas o local)
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?appName=Cluster0
# Local:  mongodb://localhost:27017
MONGO=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/votaciones-empremd?appName=Cluster0

# Nombre de la base de datos (tiene prioridad sobre la del connection string)
MONGO_DB=votaciones-empremd

# Contraseña de administrador para las rutas /api/admin protegidas
ADMIN_PASSWORD=your_admin_password_here

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
